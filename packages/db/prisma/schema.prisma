generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum PaymentType {
  REGISTRATION
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum WalletType {
  SPEND
  INCENTIVE
  WITHDRAWAL
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ServiceType {
  MOBILE_PREPAID
  DTH
  ELECTRICITY
  GAS
  WATER
  LPG_Booking
}

enum ServiceStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum EntryType {
  REGISTRATION
  REENTRY
}

enum ReentryStatus {
  PENDING
  PROCESSED
}

enum VendorRole {
  VENDOR
}

enum VendorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountType {
  SAVINGS
  CURRENT
}

enum BillRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id                    String      @id @default(cuid())
  name                  String
  phone                 String      @unique
  code                  String      @unique
  gasConsumerNumber     String      @unique
  role                  Role        @default(USER)
  isRegistrationPayment Boolean     @default(false)
  isActive              Boolean     @default(false)
  password              String
  bankDetails           BankDetail?

  sponsorId     String?
  sponsor       User?   @relation("Sponsorship", fields: [sponsorId], references: [id])
  referredUsers User[]  @relation("Sponsorship")

  // User has multiple accounts (A', A'', A''')
  accounts     UserAccount[]
  reentryQueue ReentryQueue[]

  // But only ONE set of 3 wallets (shared across all accounts)
  wallets  Wallet[]
  payments Payment[]

  // All transactions across all accounts feed here
  walletTransactions  WalletTransaction[]
  serviceTransactions ServiceTransaction[]
  vendorTransactions  VendorTransaction[]

  // Withdrawal requests
  withdrawalRequests WithdrawalRequest[]
  billRequests       BillRequest[]

  autoPays          AutoPay[]
  autoPayExecutions AutoPayExecution[]

  vendors Vendor[] @relation("vendorSponsor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sponsorId])
}

model BankDetail {
  id            String      @id @default(cuid())
  userId        String      @unique
  bankName      String
  accountNumber String
  accountType   AccountType @default(SAVINGS)
  ifscCode      String
  upiId         String?
  qrCode        String?
  gPay          String?
  createdAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

model UserAccount {
  id     String @id @default(cuid())
  userId String

  // Matrix position in the global 5x5 tree
  matrixPosition  Int     @unique // Global sequential position (1, 2, 3, ...)
  parentAccountId String? // Parent node in 5x5 tree

  // Matrix tree relationships
  parent   UserAccount?  @relation("MatrixTree", fields: [parentAccountId], references: [id])
  children UserAccount[] @relation("MatrixTree")

  // Link to master user
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Entry type
  entryType EntryType // REGISTRATION (₹199) or REENTRY (163 points)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matrixPosition])
  @@index([parentAccountId])
}

model ReentryQueue {
  id        String        @id @default(cuid())
  userId    String
  status    ReentryStatus @default(PENDING)
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, status]) // ✅ Prevents duplicate PENDING entries
  @@index([status])
}

model Wallet {
  id      String     @id @default(cuid())
  userId  String
  type    WalletType
  balance Decimal    @default(0) @db.Decimal(15, 2)

  // Link to master user
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Transactions
  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One user can only have ONE wallet of each type
  @@unique([userId, type])
}

model BillRequest {
  id     String @id @default(cuid())
  userId String

  amount     Decimal @db.Decimal(15, 2) // ₹100 — what user paid outside
  charge     Decimal @db.Decimal(15, 2) // ₹10  — 10% system fee
  totalDebit Decimal @db.Decimal(15, 2) // ₹110 — debited from spend wallet

  billImageUrl String? // uploaded screenshot
  description  String? // optional note e.g. "Petrol - HP Pump"
  category     String? // PETROL, GROCERY, FOOD etc

  status BillRequestStatus @default(PENDING)

  // wallet transaction linkage for audit
  walletTransactionId String? @unique

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum ReferenceType {
  REGISTRATION /* userAccount Id */
  REENTRY /* newly created UserAccount Id  */
  REENTRY_DEBIT /* noo need to show any name since it's a debit trxn for re-entry */
  VENDOR_COMMISSION /* vendorId */
  USER_COMMISSION /* userId */
  VENDOR_PAYMENT /* vendorId */
  RECHARGE /* serviceTransaction id */
  RECHARGE_REFUND /* serviceTransaction id */
  WITHDRAWAL
  WITHDRAWAL_REFUND
  BILL_REQUEST // debit when request raised
  BILL_REFUND // credit when rejected
  AUTOPAY
  AUTOPAY_REFUND
}

model WalletTransaction {
  id       String @id @default(cuid())
  userId   String
  walletId String

  type   TransactionType // CREDIT or DEBIT
  points Decimal         @db.Decimal(15, 2)

  description   String
  referenceType ReferenceType
  referenceId   String

  serviceTransaction ServiceTransaction?
  billRequest        BillRequest?
  // Link to user and wallet
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet             Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt        DateTime          @default(now())
  autoPayExecution AutoPayExecution?

  @@index([userId])
  @@index([walletId])
  @@index([createdAt])
}

model WithdrawalRequest {
  id     String @id @default(cuid())
  userId String

  pointsRequested  Decimal @db.Decimal(15, 2)
  serviceFee       Decimal @db.Decimal(15, 2)
  amountToTransfer Decimal @db.Decimal(15, 2)

  status WithdrawalStatus @default(PENDING)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Payment details
  amount Decimal @db.Decimal(10, 2) // ₹199.00
  points Int // 199 points

  type   PaymentType
  status PaymentStatus @default(PENDING)

  // Paytm details
  orderId       String  @unique
  transactionId String? @unique
  paytmResponse Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model ServiceTransaction {
  id     String @id @default(cuid())
  userId String

  // Service details
  serviceType  ServiceType
  operatorName String // "Airtel", "Jio", etc.
  operatorCode String // "AT", "RJ" (skey from IMWallet)
  amount       Decimal     @db.Decimal(10, 2)

  // Customer details
  mobileNumber String // Mobile number being recharged

  // IMWallet tracking
  orderId          String  @unique // Your generated order ID
  imwalletTxnId    String? @unique // requestID from IMWallet
  operatorTxnId    String? // oprID from IMWallet
  imwalletResponse Json? // Full API response

  status     ServiceStatus @default(PENDING)
  commission Decimal?      @db.Decimal(10, 2) // gross_comm from IMWallet (your profit)

  // BBPS-specific fields
  billFetchId  String? // Valid for 10 mins
  customerName String? // From fetch bill
  dueDate      DateTime? // Bill due date
  billDate     DateTime? // Bill generated date
  billedAmount Decimal?  @db.Decimal(10, 2) // Original bill amount
  partPayment  Boolean? // Whether partial payment allowed

  // Wallet linkage
  walletTransactionId String?            @unique
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model Vendor {
  id       String @id @default(cuid())
  phone    String @unique
  password String

  // Shop details
  shopName  String
  ownerName String
  category  String // GROCERY, RECHARGE, PETROL, etc.
  role      VendorRole @default(VENDOR)
  pincode   String

  // KYC Documents
  panNumber    String  @unique
  aadharNumber String  @unique
  gstNumber    String? @unique

  sponsorId String?
  sponsor   User?   @relation("vendorSponsor", fields: [sponsorId], references: [id])

  // Payment details
  bankDetails VendorBankDetail?

  // Approval workflow
  approvalStatus  VendorApprovalStatus @default(PENDING) // PENDING, APPROVED, REJECTED
  rejectionReason String?
  isActive        Boolean              @default(false)

  commissionRate Decimal @default(0.0) @db.Decimal(5, 2)

  // Vendor transactions (payments received from users)
  wallet                   VendorWallet?
  transactions             VendorTransaction[]
  vendorwithdrawalRequests VendorWithdrawalRequest[]

  // ✅ QR for payments
  paymentQr String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorBankDetail {
  id            String      @id @default(cuid())
  vendorId      String      @unique
  bankName      String
  accountNumber String
  accountType   AccountType @default(SAVINGS)
  ifscCode      String
  upiId         String?
  qrCode        String?
  gPay          String?
  createdAt     DateTime    @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_bank_details")
}

model VendorWallet {
  id                String  @id @default(cuid())
  vendorId          String  @unique // enforces one wallet per vendor
  balance           Decimal @default(0) @db.Decimal(15, 2)
  processingBalance Decimal @default(0) @db.Decimal(15, 2)

  vendor       Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions VendorTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorTransaction {
  id             String        @id @default(cuid())
  vendorId       String
  userId         String
  vendorWalletId String?
  vendorWallet   VendorWallet? @relation(fields: [vendorWalletId], references: [id])

  amount           Decimal @db.Decimal(15, 2)
  commissionAmount Decimal @default(0) @db.Decimal(15, 2) // always recorded, not nullable
  description      String

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([userId])
  @@index([createdAt])
}

model VendorWithdrawalRequest {
  id              String  @id @default(cuid())
  vendorId        String
  pointsRequested Decimal @db.Decimal(15, 2)

  status            WithdrawalStatus @default(PENDING)
  amountTransferred Decimal?         @db.Decimal(15, 2) //amt transfered
  transactionRef    String? // admin field
  settledAt         DateTime?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
}

enum AutoPayStatus {
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  PAUSED
  CANCELLED
  REJECTED
}

enum AutoPayDueDate {
  FIVE // 5th
  TEN // 10th
  FIFTEEN // 15th
}

enum AutoPayCategory {
  RENT
  SCHOOL
  COLLEGE
  EMI
  TUITION
}

enum AutoPayExecutionStatus {
  SUCCESS // deducted + bill generated
  INSUFFICIENT // skipped — not enough balance
  FAILED // unexpected error
}

model AutoPay {
  id     String @id @default(cuid())
  userId String

  beneficiaryName String
  bankName        String
  accountNumber   String
  ifscCode        String
  upiId           String?
  amount          Decimal         @db.Decimal(15, 2)
  dueDate         AutoPayDueDate
  category        AutoPayCategory

  status AutoPayStatus @default(PENDING_APPROVAL)

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions AutoPayExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

model AutoPayExecution {
  id        String @id @default(cuid())
  autoPayId String
  userId    String

  amount     Decimal @db.Decimal(15, 2) // snapshot of amount at time of execution
  charge     Decimal @db.Decimal(15, 2) // 10%
  totalDebit Decimal @db.Decimal(15, 2) // amount + charge

  status AutoPayExecutionStatus

  // Linked wallet transaction — only present on SUCCESS
  walletTransactionId String? @unique

  autoPay           AutoPay            @relation(fields: [autoPayId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  executedAt DateTime @default(now())

  @@index([autoPayId])
  @@index([userId])
  @@index([status])
  @@index([executedAt])
}

enum OperatorCode {
  RJ
  AT
  VI
  BT
  BS
}

enum RechargeCategory {
  Unlimited_5g_plans
  Top_data_packs
  Monthly_packs
  Talktime_plans
  Unlimited
}

model RechargePlan {
  id           String           @id @default(cuid())
  operatorCode OperatorCode
  category     RechargeCategory
  amount       Decimal          @db.Decimal(15, 2)
  data         String
  calls        String
  validity     String
  isActive     Boolean          @default(true) // optional but handy
  createdAt    DateTime         @default(now()) // optional
  updatedAt    DateTime         @updatedAt // optional
}
